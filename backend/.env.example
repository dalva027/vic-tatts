# Server
PORT=4000
# Where the frontend is served from (used for CORS).
CORS_ORIGIN=http://localhost:5173

# Shop owner's phone that receives a text for every new booking request.
# Use E.164 format, e.g. +15125550123
BUSINESS_PHONE=

# textbee.dev SMS gateway — https://app.textbee.dev/dashboard
# Register your Android device, then paste the device id + API key here.
# Leave BOTH blank to log SMS previews to the console instead of sending.
TEXTBEE_DEVICE_ID=
TEXTBEE_API_KEY=


